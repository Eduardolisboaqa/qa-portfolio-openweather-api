  "item": [
    {
      "name": "01 - Current Weather - Positive Tests",
      "item": [
        {
          "name": "TC001 - Get Current Weather by City - Positive Test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains city name\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "    pm.expect(response).to.have.property(\"name\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Temperature is a number\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "    pm.expect(response.main.temp).to.be.a(\"number\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Humidity is between 0 and 100\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "    pm.expect(response.main.humidity).to.be.at.least(0);\r",
                  "    pm.expect(response.main.humidity).to.be.at.most(100);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Wind speed is a number\", function () {\r",
                  "    const response = pm.response.json();\r",
                  "    pm.expect(response.wind.speed).to.be.a(\"number\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "q",
                "value": "Madrid",
                "type": "text"
              },
              {
                "key": "x-api-key",
                "value": "{{x-api-key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "https://api.openweathermap.org/data/2.5/weather?q=madrid&appid={{x-api-key}}&units=metric",
              "protocol": "https",
              "host": [
                "api",
                "openweathermap",
                "org"
              ],
              "path": [
                "data",
                "2.5",
                "weather"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "madrid"
                },
                {
                  "key": "appid",
                  "value": "{{x-api-key}}"
                },
                {
                  "key": "units",
                  "value": "metric"
                }
              ]
            }
          },
